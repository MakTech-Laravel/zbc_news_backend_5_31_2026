APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# APP_URL=http://localhost
APP_URL=https://api.zbc.maktechlaravel.cloud

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Local development: run these alongside `php artisan serve`
# php artisan queue:work --tries=3
# php artisan reverb:start
# php artisan notifications:backfill-preferences

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
NEWSLETTER_SEND_DELAY_MS=500

# Reverb credentials — MUST match REVERB_APP_* in reverb_server and
# VITE_REVERB_APP_KEY in the frontend EXACTLY.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Where the backend PUBLISHES events (server-to-server, HMAC-signed HTTP POST).
#
# On Coolify, separate apps do NOT resolve each other by service name by default,
# so use the PUBLIC WS host — the request loops back through Traefik on the same
# VPS (no real internet round-trip). The WS origin check does not apply here.
REVERB_HOST=ws.zbc.maktechlaravel.cloud
REVERB_PORT=443
REVERB_SCHEME=https
#
# ALTERNATIVE (internal Docker DNS) — only if both containers share a network
# (Coolify: enable "Connect To Predefined Network" on both, then use the name
# that actually resolves from the backend, e.g. the reverb_server container name):
#   REVERB_HOST=<resolvable-name>   REVERB_PORT=8080   REVERB_SCHEME=http

# Cross-origin: the SPA origin allowed to call the API and /broadcasting/auth.
FRONTEND_URL=https://zbc.maktechlaravel.cloud

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
CLOUDINARY_SECURE=true
CLOUDINARY_CDN_SUBDOMAIN=false
CLOUDINARY_FOLDER=production
CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_MAX_IMAGE_SIZE=10485760
CLOUDINARY_MAX_VIDEO_SIZE=524288000
CLOUDINARY_MAX_DOCUMENT_SIZE=20971520

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
